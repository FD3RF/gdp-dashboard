# AI Quant Trading System - Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# System Configuration
# ============================================
QUANT__SYSTEM_NAME=AI Quant Trading System
QUANT__SYSTEM_VERSION=1.0.0
QUANT__ENVIRONMENT=development
QUANT__DEBUG=true

# ============================================
# Database Configuration
# ============================================
QUANT__DATABASE__HOST=localhost
QUANT__DATABASE__PORT=5432
QUANT__DATABASE__NAME=quant_system
QUANT__DATABASE__USER=quant_user
QUANT__DATABASE__PASSWORD=your_db_password
QUANT__DATABASE__POOL_SIZE=10

# ============================================
# Redis Configuration
# ============================================
QUANT__REDIS__HOST=localhost
QUANT__REDIS__PORT=6379
QUANT__REDIS__DB=0
QUANT__REDIS__PASSWORD=

# ============================================
# Ollama AI Configuration
# ============================================
QUANT__OLLAMA__HOST=localhost
QUANT__OLLAMA__PORT=11434
QUANT__OLLAMA__MODEL=qwen2.5-coder:latest
QUANT__OLLAMA__TIMEOUT=300
QUANT__OLLAMA__TEMPERATURE=0.7
QUANT__OLLAMA__MAX_TOKENS=4096

# ============================================
# Risk Management Configuration
# ============================================
QUANT__RISK__MAX_POSITION_SIZE_PCT=0.02
QUANT__RISK__MAX_PORTFOLIO_LEVERAGE=3.0
QUANT__RISK__MAX_DRAWDOWN_PCT=0.15
QUANT__RISK__MAX_DAILY_LOSS_PCT=0.05
QUANT__RISK__MAX_SINGLE_TRADE_RISK_PCT=0.01

# ============================================
# Execution Configuration
# ============================================
QUANT__EXECUTION__DEFAULT_SLIPPAGE=0.0005
QUANT__EXECUTION__DEFAULT_TIMEOUT=30
QUANT__EXECUTION__MAX_RETRIES=3

# ============================================
# Exchange API Keys (TESTNET!)
# ============================================
# WARNING: Never use production keys in development!
BINANCE_API_KEY=your_binance_testnet_api_key
BINANCE_API_SECRET=your_binance_testnet_api_secret

# Bybit
BYBIT_API_KEY=your_bybit_testnet_api_key
BYBIT_API_SECRET=your_bybit_testnet_api_secret

# ============================================
# Data Collection Configuration
# ============================================
QUANT__DATA__DEFAULT_EXCHANGE=binance
QUANT__DATA__DEFAULT_TIMEFRAME=1h
QUANT__DATA__CACHE_ENABLED=true
QUANT__DATA__CACHE_TTL=3600

# ============================================
# Backtest Configuration
# ============================================
QUANT__BACKTEST__INITIAL_CAPITAL=100000.0
QUANT__BACKTEST__COMMISSION_RATE=0.001
QUANT__BACKTEST__DEFAULT_SLIPPAGE=0.0005

# ============================================
# Monitoring Configuration
# ============================================
QUANT__MONITOR__ENABLED=true
QUANT__MONITOR__LOG_LEVEL=INFO
QUANT__MONITOR__METRICS_PORT=9090
QUANT__MONITOR__HEALTH_CHECK_INTERVAL=60

# Telegram Alerts
QUANT__MONITOR__TELEGRAM_ENABLED=false
QUANT__MONITOR__TELEGRAM_TOKEN=your_telegram_bot_token
QUANT__MONITOR__TELEGRAM_CHAT_ID=your_telegram_chat_id

# Email Alerts
QUANT__MONITOR__EMAIL_ENABLED=false
QUANT__MONITOR__SMTP_HOST=smtp.gmail.com
QUANT__MONITOR__SMTP_PORT=587
QUANT__MONITOR__SMTP_USER=your_email@gmail.com
QUANT__MONITOR__SMTP_PASSWORD=your_email_password

# ============================================
# Strategy Configuration
# ============================================
QUANT__STRATEGY__DEFAULT_STRATEGY=trend_following
QUANT__STRATEGY__MAX_STRATEGIES=10
QUANT__STRATEGY__AUTO_START=false

# ============================================
# External Data APIs (Optional)
# ============================================
# Glassnode API
GLASSNODE_API_KEY=your_glassnode_api_key

# Etherscan API
ETHERSCAN_API_KEY=your_etherscan_api_key

# CryptoCompare API
CRYPTOCOMPARE_API_KEY=your_cryptocompare_api_key

# News API
NEWS_API_KEY=your_news_api_key

# Twitter/X API
TWITTER_BEARER_TOKEN=your_twitter_bearer_token
